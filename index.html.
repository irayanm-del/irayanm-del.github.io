<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rayan Al Asmi — Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* Reset & Variables */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root {
  --bg: #050507; /* Deep Midnight */
  --bg-accent: #0a0a0f;
  --card: rgba(15, 15, 20, 0.6);
  --border: rgba(255, 255, 255, 0.08);
  --border-hover: rgba(59, 130, 246, 0.4);
  --blue: #3b82f6;
  --teal: #00dfd8;
  --white: #ffffff;
  --text-main: rgba(255, 255, 255, 0.95);
  --text-mid: rgba(255, 255, 255, 0.6);
  --text-low: rgba(255, 255, 255, 0.35);
  --glow: rgba(59, 130, 246, 0.15);
}

body {
  background-color: var(--bg);
  background-image: 
    radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.05) 0%, transparent 40%),
    radial-gradient(circle at 100% 100%, rgba(0, 223, 216, 0.03) 0%, transparent 40%);
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* Custom Cursor */
#cursor {
  width: 8px; height: 8px; background: var(--white);
  border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999;
}
#cursorRing {
  width: 34px; height: 34px; border: 1.5px solid var(--blue);
  border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998;
  transition: transform 0.1s ease-out;
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.reveal {
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* Layout */
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 40px;
}

section { padding: 120px 0; }

/* Hero Section */
.hero {
  height: 90vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}

h1 {
  font-size: clamp(3rem, 8vw, 5.5rem);
  font-weight: 900;
  letter-spacing: -0.05em;
  line-height: 0.9;
  margin-bottom: 24px;
  background: linear-gradient(180deg, #fff 0%, rgba(255,255,255,0.7) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-tagline {
  font-family: 'DM Mono', monospace;
  color: var(--blue);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  font-size: 0.9rem;
  margin-bottom: 16px;
}

.hero-desc {
  font-size: 1.25rem;
  color: var(--text-mid);
  max-width: 600px;
}

/* Grid & Cards */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 24px;
}

.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 40px;
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  overflow: hidden;
}

.card:hover {
  border-color: var(--border-hover);
  transform: translateY(-8px);
  background: rgba(20, 20, 28, 0.8);
  box-shadow: 0 20px 40px rgba(0,0,0,0.3), 0 0 20px var(--glow);
}

.card-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  color: var(--blue);
  margin-bottom: 12px;
  display: block;
}

.card h3 {
  font-size: 1.5rem;
  margin-bottom: 16px;
}

.card p {
  color: var(--text-mid);
  font-size: 0.95rem;
}

/* Professional Expertise List */
.skill-item {
  display: flex;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}

/* Contact / Footer */
footer {
  padding: 60px 0;
  border-top: 1px solid var(--border);
  text-align: center;
}

.footer-name {
  font-weight: 700;
  letter-spacing: -0.02em;
}

.footer-sub {
  color: var(--text-low);
  font-size: 0.85rem;
  margin-top: 8px;
}

/* AI Beam Effect */
#beam {
  position: fixed;
  top: 0; left: 0; width: 100%; height: 2px;
  background: linear-gradient(90deg, transparent, var(--blue), transparent);
  opacity: 0.3;
  z-index: 1000;
  pointer-events: none;
  animation: scan 8s linear infinite;
}

@keyframes scan {
  0% { transform: translateY(-100vh); }
  100% { transform: translateY(200vh); }
}

@media (max-width: 768px) {
  .container { padding: 0 24px; }
  section { padding: 80px 0; }
}
</style>
</head>
<body>

<div id="cursor"></div>
<div id="cursorRing"></div>
<div id="beam"></div>

<main class="container">
  <section class="hero reveal">
    <span class="hero-tagline">Marketing & Communication Lead</span>
    <h1>Rayan<br>Al Asmi.</h1>
    <p class="hero-desc">Building high-impact brand stories and world-class experiential marketing for global platforms in Saudi Arabia.</p>
  </section>

  <section id="expertise">
    <h2 style="margin-bottom: 48px; font-size: 2rem; letter-spacing: -0.03em;">Core Expertise</h2>
    <div class="grid">
      <div class="card reveal">
        <span class="card-label">01</span>
        <h3>Integrated Communication</h3>
        <p>Strategic branding, messaging, and stakeholder engagement to drive business priorities.</p>
      </div>
      <div class="card reveal" style="animation-delay: 0.1s;">
        <span class="card-label">02</span>
        <h3>Media & PR</h3>
        <p>Crafting narratives for global outlets including Al Arabiya, Arab News, and Saudi Gazette.</p>
      </div>
      <div class="card reveal" style="animation-delay: 0.2s;">
        <span class="card-label">03</span>
        <h3>Strategic Events</h3>
        <p>Driving presence at G20, LEAP, FII, and Global Health Exhibition.</p>
      </div>
    </div>
  </section>

  <section id="tools">
    <h2 style="margin-bottom: 48px; font-size: 2rem;">Design & AI Stack</h2>
    <div class="card reveal">
      <div class="skill-item"><span>Design</span><span style="color:var(--blue)">Illustrator / Photoshop / Canva</span></div>
      <div class="skill-item"><span>AI Tools</span><span style="color:var(--blue)">Midjourney / Runway / Sora</span></div>
      <div class="skill-item"><span>Management</span><span style="color:var(--blue)">Sprout Social / CMS / MS Office</span></div>
    </div>
  </section>

  <section id="contact" style="text-align: center;">
    <h2 style="margin-bottom: 24px;">Let's Connect</h2>
    <p style="color: var(--text-mid); margin-bottom: 40px;">Riyadh, Saudi Arabia</p>
    <a href="#" style="color: var(--white); text-decoration: none; border: 1px solid var(--blue); padding: 12px 32px; border-radius: 30px; font-family: 'DM Mono';">View Resume →</a>
  </section>
</main>

<footer>
  <div class="footer-name">Rayan Al Asmi — 2026</div>
  <div class="footer-sub">Marketing · Branding · Strategic Events</div>
</footer>

<script>
// Smooth Cursor
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mouseX = 0, mouseY = 0;
let ringX = 0, ringY = 0;

document.addEventListener('mousemove', (e) => {
  mouseX = e.clientX;
  mouseY = e.clientY;
  cursor.style.transform = `translate(${mouseX - 4}px, ${mouseY - 4}px)`;
});

function animate() {
  ringX += (mouseX - ringX - 17) * 0.15;
  ringY += (mouseY - ringY - 17) * 0.15;
  ring.style.transform = `translate(${ringX}px, ${ringY}px)`;
  requestAnimationFrame(animate);
}
animate();

// Reveal animations on scroll
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('reveal');
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

</body>
</html>
