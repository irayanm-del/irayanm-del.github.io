<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rayan Al Asmi — Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* Reset & Variables */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root {
  --bg: #050507;
  --card: rgba(15, 15, 20, 0.6);
  --border: rgba(255, 255, 255, 0.08);
  --blue: #3b82f6;
  --text-main: rgba(255, 255, 255, 0.95);
  --text-mid: rgba(255, 255, 255, 0.6);
}

html { scroll-behavior: smooth; }

body {
  background-color: var(--bg);
  background-image: radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.05) 0%, transparent 40%);
  color: var(--text-main);
  font-family: 'Inter', sans-serif;
  cursor: none; /* Required for custom cursor */
  overflow-x: hidden;
}

/* Custom Cursor Fix */
#cursor {
  width: 8px; height: 8px; background: #fff;
  border-radius: 50%; position: fixed; pointer-events: none; z-index: 10000;
}
#cursorRing {
  width: 34px; height: 34px; border: 1.5px solid var(--blue);
  border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999;
}

/* Navigation */
nav {
  position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
  width: 90%; max-width: 1100px; padding: 15px 30px;
  background: rgba(10, 10, 15, 0.5); backdrop-filter: blur(20px);
  border: 1px solid var(--border); border-radius: 50px;
  display: flex; justify-content: space-between; align-items: center; z-index: 1000;
}
.nav-links { display: flex; gap: 25px; list-style: none; }
.nav-links a { color: var(--text-mid); text-decoration: none; font-size: 0.85rem; transition: 0.3s; }
.nav-links a:hover { color: #fff; }

/* Hero Section Fix */
.hero {
  height: 100vh; display: flex; flex-direction: column; 
  justify-content: center; padding: 0 10%; position: relative;
}
.hero-bg {
  position: absolute; inset: 0; 
  z-index: 1; pointer-events: none; /* Fixed: Prevents blocking buttons */
}
.hero-content { position: relative; z-index: 2; } /* Fixed: Brings content to front */

h1 { font-size: clamp(3rem, 8vw, 5.5rem); font-weight: 900; line-height: 1; margin-bottom: 20px; }
.blue-text { color: var(--blue); }

/* Buttons Fix */
.hero-cta { display: flex; gap: 15px; margin-top: 30px; }
.btn {
  padding: 14px 32px; border-radius: 50px; text-decoration: none;
  font-weight: 600; font-size: 0.9rem; transition: 0.3s;
  display: inline-block; cursor: pointer;
}
.btn-p { background: var(--blue); color: #fff; border: 1px solid var(--blue); }
.btn-s { background: transparent; color: #fff; border: 1px solid var(--border); backdrop-filter: blur(10px); }
.btn:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.3); }

/* Standard Sections */
.section { padding: 100px 10%; border-top: 1px solid var(--border); }
.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
.card { background: var(--card); border: 1px solid var(--border); padding: 30px; border-radius: 15px; }

/* AI Scan Animation */
.scan-beam {
  position: absolute; top: 0; left: 0; width: 100%; height: 2px;
  background: linear-gradient(90deg, transparent, var(--blue), transparent);
  animation: scan 6s linear infinite; z-index: 1;
}
@keyframes scan { 0% { top: 0; } 100% { top: 100%; } }

</style>
</head>
<body>

<div id="cursor"></div>
<div id="cursorRing"></div>

<nav>
  <div style="font-weight:800; letter-spacing: 2px;">R · A</div>
  <ul class="nav-links">
    <li><a href="#home">Home</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#work">Work</a></li>
    <li><a href="https://drive.google.com/file/d/1I9wzBt0G1y8YjBPavAXJscGO1_qTxnof/view?usp=sharing" target="_blank" style="color:var(--blue)">Resume</a></li>
  </ul>
</nav>

<section class="hero" id="home">
  <div class="hero-bg"></div>
  <div class="scan-beam"></div>
  <div class="hero-content">
    <p style="font-family:'DM Mono'; color:var(--blue); margin-bottom: 10px;">PORTFOLIO 2026</p>
    <h1>Rayan<br><span class="blue-text">Al Asmi</span></h1>
    <p style="max-width: 500px; color: var(--text-mid);">Marketing & Communication Lead. Let's make an impact that the world remembers.</p>
    <div class="hero-cta">
      <a href="#work" class="btn btn-p">View My Work</a>
      <a href="#contact" class="btn btn-s">Get In Touch</a>
    </div>
  </div>
</section>

<section class="section" id="about">
  <h2 style="margin-bottom:30px">About Me</h2>
  <p style="font-size: 1.2rem; color: var(--text-mid);">Marketing & Communication professional with 6+ years of experience leading strategic communications for platforms like G20 and LEAP.</p>
</section>

<section class="section" id="work">
  <h2 style="margin-bottom:30px">Featured Work</h2>
  <div class="grid">
    <div class="card">
      <h3 style="margin-bottom:10px">Experiential Marketing</h3>
      <p style="color:var(--text-mid)">Strategic event participation and sponsorship activations for global platforms.</p>
    </div>
    <div class="card">
      <h3 style="margin-bottom:10px">Strategic Branding</h3>
      <p style="color:var(--text-mid)">Brand identity and creative direction for high-profile entities.</p>
    </div>
  </div>
</section>

<section class="section" id="contact" style="text-align:center">
  <h2>Let's Connect</h2>
  <p style="margin: 20px 0; color:var(--text-mid)">Riyadh, Saudi Arabia</p>
  <a href="mailto:rayan@example.com" class="btn btn-p">Send an Email</a>
</section>

<script>
// Fixed Cursor Logic
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mouseX = 0, mouseY = 0;
let ringX = 0, ringY = 0;

document.addEventListener('mousemove', (e) => {
  mouseX = e.clientX;
  mouseY = e.clientY;
  cursor.style.left = mouseX - 4 + 'px';
  cursor.style.top = mouseY - 4 + 'px';
});

function animate() {
  ringX += (mouseX - ringX - 17) * 0.15;
  ringY += (mouseY - ringY - 17) * 0.15;
  ring.style.left = ringX + 'px';
  ring.style.top = ringY + 'px';
  requestAnimationFrame(animate);
}
animate();

// Smooth scroll for buttons
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelector(this.getAttribute('href')).scrollIntoView({
            behavior: 'smooth'
        });
    });
});
</script>

</body>
</html>
